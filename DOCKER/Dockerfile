# The source image to start with
FROM alpine:3.20.3

# Your contact info
MAINTAINER wiggal ;ludwig.sporrer@gmx.de

# Setzen der Umgebungsvariablen für die deutsche Sprache
ENV CONTAINER_TIMEZONE="Europe/Berlin" \
    LANG=de_DE.UTF-8 \
    LANGUAGE=de_DE:de \
    LC_ALL=de_DE.UTF-8

RUN apk add --update-cache git
#git clon_Ladesteuerung-main/ nach /home/GEN24
RUN git clone -b main https://github.com/wiggal/GEN24_Ladesteuerung.git /home/GEN24

RUN apk add --update-cache \
    php-openssl \
    php \
    php-json \
    php-sqlite3 \
    php-cli \
    php-posix \
    php-curl \
    tzdata \
    python3 \
    py-pip \
    bash \
    file \
    py3-yaml \
    py3-aiohttp \
    py3-websockets \
    py3-requests \
    py3-pandas \
    py3-numpy \
  && rm -rf /var/cache/apk/* \
&& cp /usr/share/zoneinfo/Europe/Berlin /etc/localtime \
&& echo "# DO NOT EDIT THIS FILE - edit the master and reinstall." >>/var/tmp/www-data \
&& echo "# Scheduler EnergyWIGGAL" >>/var/tmp/www-data \
&& echo "* * * * * /usr/bin/python3 /home/GEN24/db_scheduler.py" >>/var/tmp/www-data \
&& chmod +x /home/GEN24/start_* \
&& >> /home/GEN24/Crontab.log \
&& echo "alias ll='ls -alF'" >> /root/.bashrc \
&& touch /var/log/cron.log

# Alle Befehle die Nach dem Imagestart ausgeführt werden müssen
CMD ["sh", "/home/GEN24/DOCKER/docker-entrypoint.sh"]
